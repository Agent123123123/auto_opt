# ---------------------------------------------------------------------------
# Required environment variables for Phase 1a evaluation loop
# Copy this file to .env and fill in your actual values.
# ---------------------------------------------------------------------------

# Meta Agent + Judge Agent -- GitHub Copilot Claude Sonnet 4.6
# Requires a GitHub OAuth token (ghu_...) obtained via the device-code flow.
# Classic PATs (ghp_...) do NOT work with the Copilot API.
#
# To generate a token:
#   1. POST https://github.com/login/device/code  (client_id: Iv1.b507a08c87ecfe98)
#   2. Visit the returned verification_uri and enter the user_code
#   3. Exchange at https://github.com/login/oauth/access_token
#
# At runtime, runtime_config.py auto-exchanges this ghu_ token for a short-lived
# Copilot bearer token (expires ~30 min; cached and refreshed automatically).
GITHUB_TOKEN=ghu_your_oauth_token_here

# GitHub PAT (Classic) -- for GitHub REST API operations (create repo, push, etc.)
# Requires scopes: repo, admin:org
# Generate at: github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
GITHUB_PAT=ghp_your_classic_pat_here

# Task Agent -- Alibaba Cloud DashScope GLM-5 (Anthropic-compatible endpoint)
# Get your key from https://dashscope.console.aliyun.com/apiKey
OPT_TASK_AGENT_KEY=sk-sp-your_dashscope_key_here
